{
  "name": "almanach",
  "version": "0.1.0",
  "description": "A file-based SceneryStack knowledge base, designed to be equally readable by humans and LLM agents",
  "type": "module",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/veillette/Almanach.git"
  },
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "VITEPRESS_BASE=/ vitepress dev docs",
    "build": "npm run generate && npm run demos:check && npm run demos:typecheck && vitepress build docs",
    "preview": "vitepress preview docs",
    "generate": "tsx scripts/generate-llm-artifacts.ts",
    "demos:check": "tsx scripts/check-demos.ts",
    "demos:typecheck": "tsc --noEmit -p tsconfig.demos.json",
    "typecheck": "tsc --noEmit",
    "coverage:status": "tsx scripts/coverage-status.ts"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "gray-matter": "^4.0.3",
    "scenerystack": "3.0.0",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vitepress": "^1.6.4"
  }
}
